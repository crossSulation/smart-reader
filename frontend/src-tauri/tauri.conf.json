{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Smart Reader",
  "version": "0.1.0",
  "identifier": "com.smartreader.app",
  "build": {
    "beforeDevCommand": {
      "cwd": "..",
      "script": "npm run dev -- --host 0.0.0.0"
    },
    "beforeBuildCommand": {
      "cwd": "..",
      "script": "npm run build"
    },
    "devUrl": "http://192.168.9.170:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Smart Reader",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "android": {
      "minSdkVersion": 26
    },
    "iOS": {
      "minimumSystemVersion": "13.0"
    }
  },
  "plugins": {
    "sqlx": {}
  }
}
